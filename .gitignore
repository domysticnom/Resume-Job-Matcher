# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.egg-info/
.ipynb_checkpoints/

# --- Secrets ---
kaggle.json
*.key

# --- Large / regenerated artifacts: keep the folder skeleton only ---
data/**
!data/**/
!data/**/.gitkeep
# The job corpus WITH precomputed skills ships with the repo so the app (and the
# HF Space) never has to run NER over the whole corpus at query time.
!data/processed/job_postings.csv
models/**
!models/**/
!models/**/.gitkeep

# --- OS / editor junk ---
.DS_Store
~$*.docx
